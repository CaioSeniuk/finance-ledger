# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/finance_ledger?schema=public

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=finance-ledger
KAFKA_GROUP_ID=finance-ledger-worker

# Redis
REDIS_URL=redis://localhost:6379

# Idempotency / Security
IDEMPOTENCY_TTL_SECONDS=86400
JWT_SECRET=<replace-with-secure-secret>
